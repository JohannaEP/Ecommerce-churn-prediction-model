   "source": [
    "# 📌 1. Importación de librerías\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "sns.set(style=\"whitegrid\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 📌 2. Cargar dataset original\n",
    "df = pd.read_csv(\"../data/data.csv\")\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📌 3. Limpieza inicial\n",
    "- Eliminar duplicados\n",
    "- Normalizar nombres de columnas\n",
    "- Corregir tipos de datos"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Eliminar duplicados\n",
    "df.drop_duplicates(inplace=True)\n",
    "\n",
    "# Normalizar nombres de columnas\n",
    "df.columns = df.columns.str.lower().str.replace(' ', '_')\n",
    "\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📌 4. Tratamiento de valores faltantes"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Ver valores faltantes\n",
    "df.isnull().sum()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Ejemplo de imputación (ajustar según dataset real)\n",
    "num_cols = df.select_dtypes(include=['float64', 'int64']).columns\n",
    "cat_cols = df.select_dtypes(include=['object']).columns\n",
    "\n",
    "# Imputación numérica\n",
    "df[num_cols] = df[num_cols].fillna(df[num_cols].median())\n",
    "\n",
    "# Imputación categórica\n",
    "df[cat_cols] = df[cat_cols].fillna('Unknown')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📌 5. Feature Engineering\n",
    "- Crear variables nuevas\n",
    "- Transformaciones útiles\n",
    "- Ejemplo: días desde la última compra"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Ejemplo: convertir fecha a datetime\n",
    "if 'last_purchase_date' in df.columns:\n",
    "    df['last_purchase_date'] = pd.to_datetime(df['last_purchase_date'], errors='coerce')\n",
    "\n",
    "    # Crear variable: días desde la última compra\n",
    "    df['days_since_last_purchase'] = (pd.Timestamp.today() - df['last_purchase_date']).dt.days"
   ]
  },
  {
   "cell_type": "markdown",
